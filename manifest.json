{
  "manifest_version": 3,
  "name": "OmniTab",
  "version": "1.0.0",
  "description": "Copy all open tabs and unpack them anywhere",
  "permissions": [
    "tabs",
    "windows",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OmniTab"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}